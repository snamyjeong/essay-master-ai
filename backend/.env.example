# PostgreSQL 데이터베이스 연결 URL (Docker 컨테이너 내부에서 접근할 호스트명 사용)
DATABASE_URL="postgresql+asyncpg://user:password@db:5432/essay_db"
# JWT 토큰 서명에 사용될 비밀 키 (매우 중요! 실제 배포 시 강력한 무작위 문자열로 변경)
SECRET_KEY="your-super-secret-key"
# Google Gemini API 키 (RAG 시스템의 임베딩 모델 사용을 위해 필요)
GEMINI_API_KEY="your-gemini-api-key"
